{
  "name": "google-system-design",
  "version": "1.0.0",
  "description": "Google System Design Video - Made with Remotion",
  "scripts": {
    "start": "npx remotion studio",
    "build": "npx remotion render GoogleSystemDesign out/google-system-design.mp4",
    "render": "npx remotion render GoogleSystemDesign out/google-system-design.mp4 --gl=angle",
    "upgrade": "npx remotion upgrade"
  },
  "dependencies": {
    "remotion": "4.0.445",
    "@remotion/cli": "4.0.445",
    "@remotion/renderer": "4.0.445",
    "@remotion/bundler": "4.0.445",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/react": "18.3.11",
    "@types/react-dom": "18.3.1",
    "typescript": "5.6.3"
  }
}
